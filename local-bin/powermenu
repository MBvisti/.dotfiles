#!/bin/bash

entries="’ĆŻ  Lock\n’ĆĪ  Reboot\n’Ćæ  Power Off"
selected=$(echo -e "$entries" | GDK_BACKEND=wayland wofi --dmenu --prompt "Power Menu" --cache-file /dev/null)

case "$selected" in
  "’ĆŻ  Lock") hyprlock ;;
  "’ĆĪ  Reboot") systemctl reboot ;;
  "’Ćæ  Power Off") systemctl poweroff ;;
esac
