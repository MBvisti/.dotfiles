#!/usr/bin/env bash

# Toggle wifi on/off via right click
if [ "$1" = "toggle" ]; then
    state=$(nmcli radio wifi)
    if [ "$state" = "enabled" ]; then
        nmcli radio wifi off
    else
        nmcli radio wifi on
    fi
    exit 0
fi

# List and connect to wifi networks
networks=$(nmcli -t -f SSID,SECURITY device wifi list 2>/dev/null | awk -F: '!seen[$1]++ && $1!="" {print $1}')

if [ -z "$networks" ]; then
    notify-send "WiFi" "No networks found" 2>/dev/null || true
    exit 0
fi

selected=$(echo "$networks" | tofi --prompt-text "WiFi: ")

if [ -n "$selected" ]; then
    nmcli device wifi connect "$selected" 2>&1 | notify-send "WiFi" "Connecting..." 2>/dev/null || true
fi
